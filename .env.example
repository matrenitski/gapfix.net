# Reddit signup script
REDDIT_PASSWORD=

# Telegram bot for 2FA/OTP relay to board (@matrenitski)
# 1. Message @BotFather on Telegram → /newbot → copy the HTTP API token
# 2. Start a chat with your bot, then call:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    and copy the chat.id value
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CAPTCHA solving (2captcha.com — ~$1/1000 solves)
# Without this key, the script falls back to Telegram relay (board solves in browser)
CAPTCHA_API_KEY=
